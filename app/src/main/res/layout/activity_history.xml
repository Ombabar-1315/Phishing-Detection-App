<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_history.xml
    History Screen — shows all past scans in a scrollable list.

    Location to save this file in Android Studio:
    app > res > layout > activity_history.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- ── Title Bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan History"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All your previous scans"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

    </LinearLayout>

    <!-- ── Divider ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- ── Empty state (shown when no scans yet) ── -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No scans yet.\nGo back and scan your first URL!"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone"
        android:lineSpacingExtra="6dp"/>

    <!-- ── RecyclerView — scan list fills here ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

</LinearLayout>