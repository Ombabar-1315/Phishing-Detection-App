<?xml version="1.0" encoding="utf-8"?>
<!--
    pill_outline.xml
    Rounded outline shape used for feature pills on splash screen.
    e.g. "URL Scan"  "QR Detect"  "SMS Guard"

    Location: app > res > drawable > pill_outline.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="20dp"/>

    <stroke
        android:width="1dp"
        android:color="#80FFFFFF"/>  <!-- semi-transparent white border -->

    <solid android:color="#20FFFFFF"/> <!-- very light white fill -->

</shape>