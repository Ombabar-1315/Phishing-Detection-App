<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_shield.xml
    Shield icon with a checkmark — represents security/protection.

    Location: app > res > drawable > ic_shield.xml
    Right-click drawable → New → Drawable Resource File → name: ic_shield
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer shield shape -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,1L3,5v6c0,5.55 3.84,10.74 9,12 5.16,-1.26 9,-6.45 9,-12L21,5z"/>

    <!-- Inner shield (blue fill for depth) -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M12,3.18L5,6.3v4.7c0,4.52 3.13,8.75 7,9.93 3.87,-1.18 7,-5.41 7,-9.93L19,6.3z"/>

    <!-- Checkmark tick -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.3"
        android:pathData="M10,14.17L7.83,12l-1.42,1.41L10,17 17,10l-1.41,-1.41z"/>

</vector>